# ============================================================
# 远声 / Talk To Global — Edge Functions Environment Variables
# Set these in Supabase Dashboard → Edge Functions → Secrets
# ============================================================

# ---- Supabase (auto-injected by Supabase, do not set manually) ----
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LLM Provider ----
# Supported: openai, anthropic, custom
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Anthropic example:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-api-key
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-20250514

# Custom endpoint (e.g. Azure, local, proxy):
# LLM_PROVIDER=custom
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://your-endpoint.com/v1
# LLM_MODEL=your-model-name

# ---- mimo ASR (Speech-to-Text) ----
MIMO_ASR_API_KEY=your-mimo-api-key
MIMO_ASR_BASE_URL=https://api.xiaomimimo.com
MIMO_ASR_MODEL=mimo-v2.5-asr
